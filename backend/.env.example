# ───────────────────────────────────
# FitTrackPro — Backend configuration
# ───────────────────────────────────

# Server
APP_PORT=8080                 # Puerto donde escucha el servidor HTTP

# PostgreSQL
DB_HOST=localhost             # Host de la base de datos
DB_PORT=5432                  # Puerto de PostgreSQL (default: 5432)
DB_USER=postgres              # Usuario de la base de datos
DB_PASSWORD=postgres          # Contraseña del usuario
DB_NAME=fittrackpro           # Nombre de la base de datos
DB_SSLMODE=disable            # SSL mode (disable, require, verify-ca, verify-full)

# JWT Auth
JWT_SECRET=change-me-in-production   # Clave secreta para firmar tokens JWT
JWT_EXPIRATION_HOURS=24              # Duración del token en horas

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8081   # Orígenes permitidos (separados por coma)

# Users
DEFAULT_USER_PASSWORD=ChangeMe123!   # Contraseña por defecto para usuarios creados por admin
