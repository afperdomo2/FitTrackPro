{
  "name": "fittrackpro",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "clean": "turbo clean",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "dev:api": "cd backend && make dev-api",
    "dev:web": "pnpm --filter web dev",
    "dev:mobile": "pnpm --filter mobile start",
    "build:api": "cd backend && make build-api",
    "build:web": "pnpm --filter web build",
    "build:mobile": "pnpm --filter mobile build",
    "test:api": "cd backend && make test-api",
    "swagger:api": "cd backend && make swagger",
    "deps:api": "cd backend && make deps",
    "lint:api": "cd backend && make lint",
    "format:api": "cd backend && go fmt ./...",
    "deploy:web": "pnpm --filter web deploy",
    "deploy:mobile": "pnpm --filter mobile deploy:web"
  },
  "devDependencies": {
    "turbo": "^2.5.0",
    "prettier": "^3.5.0",
    "typescript": "^5.8.0"
  },
  "packageManager": "pnpm@10.30.3",
  "engines": {
    "node": ">=22"
  }
}
